# Demos Fleet Oracle — Environment Configuration
# Copy this file to .env and fill in your values

# Required: Your Demos Network wallet mnemonic (12 words)
DEMOS_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Required: Your local Demos node RPC endpoint
DEMOS_RPC_URL=http://127.0.0.1:53550

# SuperColony endpoint (don't change)
COLONY_URL=https://www.supercolony.ai

# How often to publish on-chain (milliseconds, default 20min)
PUBLISH_INTERVAL_MS=1200000

# How often to monitor fleet (milliseconds, default 1min)
MONITOR_INTERVAL_MS=60000

# Telegram bot token (optional, for alerts)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram chat ID (optional, for alerts)
TELEGRAM_CHAT_ID=your_chat_id_here

# Port to serve the health API on
HEALTH_PORT=55225

# Instance role: primary, validator, or backup
# primary: always publishes
# validator: only publishes if primary is silent
# backup: always publishes independently
INSTANCE_ROLE=primary

# URL of primary oracle (required for validator role only)
# PRIMARY_ORACLE_URL=http://193.77.169.106:55225
